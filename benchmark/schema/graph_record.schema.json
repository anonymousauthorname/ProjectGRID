{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GraphRecord",
  "type": "object",
  "required": ["entities", "relations"],
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "alias": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sub", "rel", "obj"],
        "properties": {
          "sub": {
            "type": "string"
          },
          "rel": {
            "type": "string"
          },
          "obj": {
            "type": "string"
          },
          "rel_type": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
